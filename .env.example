# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_SIGNALING_URL: WebSocket URL for the signaling server (e.g., wss://my-signaling-server.com)
VITE_SIGNALING_URL="wss://YOUR-SIGNALING-SERVER-URL"

